# ============================================================
# OmniPOS — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# --- Supabase (obligatoire) ---
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_clé_anon_publique

# --- Stripe (optionnel — nécessaire pour les paiements en ligne) ---
# Voir docs/STRIPE_SETUP.md pour la configuration complète
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_LIFETIME_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_CHECKOUT_URL=/api/create-checkout

# --- Auth0 (optionnel — alternative à Supabase Auth) ---
# Voir docs/AUTH0_SETUP.md pour la configuration complète
VITE_AUTH0_DOMAIN=votre-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AUTH0_CALLBACK_URL=http://localhost:5177/login
